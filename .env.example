SERVER_HOST=0.0.0.0
SERVER_PORT=8090

# SSL 配置（非 localhost 访问时必须启用，否则浏览器会禁用麦克风）
SSL_CERTFILE=certs/cert.pem
SSL_KEYFILE=certs/key.pem
FUNASR_HOST=localhost
FUNASR_PORT=10095
FUNASR_MODE=offline
LLM_API_BASE=https://api.deepseek.com/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL=deepseek-chat
RETENTION_DAYS=7
MAX_AUDIO_SIZE_MB=100

# DashScope (阿里百炼) ASR 配置
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_ASR_MODEL_REALTIME=paraformer-realtime-v2
DASHSCOPE_ASR_MODEL_FILE=paraformer-v2
# 服务器公网地址（文件转写模式需要 DashScope 能访问到服务器音频文件）
SERVER_PUBLIC_URL=http://your-server-public-ip:8090
